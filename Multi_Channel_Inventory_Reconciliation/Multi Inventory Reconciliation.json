    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n    m.sku,\n    m.product_name,\n    m.master_quantity,\n    MAX(CASE WHEN s.channel='shopify' THEN s.quantity END) AS shopify,\n    MAX(CASE WHEN s.channel='amazon' THEN s.quantity END) AS amazon,\n    MAX(CASE WHEN s.channel='ebay' THEN s.quantity END) AS ebay,\n    MAX(CASE WHEN s.channel='etsy' THEN s.quantity END) AS etsy,\n    MAX(CASE WHEN s.channel='tiktok' THEN s.quantity END) AS tiktok\nFROM master_inventory m\nLEFT JOIN inventory_snapshots s ON m.sku = s.sku\nGROUP BY m.sku, m.product_name, m.master_quantity\nORDER BY m.sku;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        -912,
        1616
      ],
      "id": "e94c8ee8-688f-4f2c-bc8d-3470d88b9907",
      "name": "Execute a SQL query",
      "credentials": {
        "postgres": {
          "id": "XvU8srQhM0siFrj7",
          "name": "Postgres account minventory"
        }
