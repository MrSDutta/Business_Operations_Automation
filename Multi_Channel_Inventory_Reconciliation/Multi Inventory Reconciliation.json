    {
      "parameters": {
        "jsCode": "const output = [];\n\nfor (const item of $input.all()) {\n  try {\n    const data = item.json;\n    const timestamp = new Date().toISOString();\n\n    // Shopify\n    if (data.inventory_levels) {\n      for (const inv of data.inventory_levels) {\n        output.push({\n          json: {\n            channel: \"shopify\",\n            sku: inv.inventory_item_id,\n            quantity: inv.available,\n            snapshot_time: timestamp\n          }\n        });\n      }\n    }\n    // Amazon\n    else if (data.payload?.inventorySummaries) {\n      for (const inv of data.payload.inventorySummaries) {\n        output.push({\n          json: {\n            channel: \"amazon\",\n            sku: inv.sellerSku,\n            quantity: inv.inventoryDetails.fulfillableQuantity,\n            snapshot_time: timestamp\n          }\n        });\n      }\n    }\n    // eBay\n    else if (data.responses) {\n      for (const inv of data.responses) {\n        output.push({\n          json: {\n            channel: \"ebay\",\n            sku: inv.sku,\n            quantity: inv.availability.shipToLocationAvailability.quantity,\n            snapshot_time: timestamp\n          }\n        });\n      }\n    }\n    // Etsy\n    else if (data.products) {\n      for (const inv of data.products) {\n        output.push({\n          json: {\n            channel: \"etsy\",\n            sku: inv.sku,\n            quantity: inv.offerings[0].quantity,\n            snapshot_time: timestamp\n          }\n        });\n      }\n    }\n    // TikTok\n    else if (data.data?.inventory_info) {\n      for (const inv of data.data.inventory_info) {\n        output.push({\n          json: {\n            channel: \"tiktok\",\n            sku: inv.sku_id,\n            quantity: inv.inventory[0].available_quantity,\n            snapshot_time: timestamp\n          }\n        });\n      }\n    }\n  } catch (e) {\n    console.log('Parse error:', e.message);\n  }\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
