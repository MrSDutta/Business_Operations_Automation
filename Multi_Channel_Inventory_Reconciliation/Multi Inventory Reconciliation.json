    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const api = $('Loop Over Items').item.json;   // this iteration's channel/sku/quantity\nconst master = $input.item.json;              // this iteration's master row\n\nif (!master || !master.sku) {\n  return {\n    json: {\n      sku: api.sku,\n      channel: api.channel,\n      master_quantity: null,\n      channel_quantity: api.quantity,\n      difference: null,\n      status: \"UNKNOWN_SKU\",\n      remarks: \"SKU not found in master inventory\"\n    }\n  };\n}\n\nconst difference = api.quantity - master.master_quantity;\n\nreturn {\n  json: {\n    sku: api.sku,\n    channel: api.channel,\n    master_quantity: master.master_quantity,\n    channel_quantity: api.quantity,\n    difference,\n    status: difference === 0 ? \"MATCH\" : Math.abs(difference) <= 2 ? \"MONITOR\" : \"DISCREPANCY\",\n    remarks: `Master: ${master.master_quantity}, ${api.channel}: ${api.quantity}`\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
