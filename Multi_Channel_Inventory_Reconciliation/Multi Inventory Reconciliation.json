        "jsCode": "let message = `🚨 Inventory Discrepancies (${items.length})\\n\\n`;\n\nfor (const item of items) {\n  if (item.json.status === \"DISCREPANCY\") {\n    message += `${item.json.sku} | ${item.json.channel} | ${item.json.master_quantity} → ${item.json.channel_quantity}\\n`;\n  }\n}\n\nreturn [{\n  json: {\n    text: message\n  }\n}];"
