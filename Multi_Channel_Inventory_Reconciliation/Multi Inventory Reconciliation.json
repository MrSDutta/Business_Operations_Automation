    {
      "parameters": {
        "jsCode": "const products = [];\n\nfor (const item of $input.all()) {\n  const p = item.json;\n\n  const channels = {\n    shopify: p.shopify,\n    amazon: p.amazon,\n    ebay: p.ebay,\n    etsy: p.etsy,\n    tiktok: p.tiktok,\n  };\n\n  const values = Object.values(channels).filter(v => v !== null && v !== undefined);\n\n  const hasMissing = Object.values(channels).some(v => v === null || v === undefined);\n\n  let status = \"match\";\n  let drift = 0;\n\n  if (values.length) {\n    drift = Math.max(...values) - Math.min(...values);\n  }\n\n  if (hasMissing) {\n    status = \"no_data\";\n  } else if (drift > 2) {\n    status = \"critical\";\n  } else if (drift > 0) {\n    status = \"monitor\";\n  }\n\n  const matchedChannels = values.filter(v => v === p.master_quantity).length;\n\n  products.push({\n    sku: p.sku,\n    product: p.product_name,\n    master: p.master_quantity,\n    channels,\n    drift,\n    matchedChannels,\n    status,\n  });\n}\n\nconst summary = {\n  total: products.length,\n  matched: products.filter(p => p.status === \"match\").length,\n  monitored: products.filter(p => p.status === \"monitor\").length,\n  critical: products.filter(p => p.status === \"critical\").length,\n};\n\nreturn [\n  {\n    json: {\n      products,\n      summary,\n    },\n  },\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
