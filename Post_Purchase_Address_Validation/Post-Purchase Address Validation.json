        "query": "UPDATE orders\nSET\n    warehouse_order_id = $1,\n    warehouse_status = $2,\n    warehouse_name = $3,\n    estimated_pick_time = $4,\n    updated_at = NOW()\nWHERE order_id = $5\nRETURNING\n    order_id,\n    warehouse_order_id,\n    warehouse_status AS status,\n    warehouse_name AS warehouse,\n    estimated_pick_time;",
        "options": {
          "queryReplacement": "={{ $json.warehouse_order_id }},{{ $json.warehouse_status }},{{ $json.warehouse_name }},{{ $json.estimated_pick_time }},{{ $json.order_id }}"
