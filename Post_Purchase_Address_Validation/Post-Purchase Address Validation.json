        "query": "SELECT\n    o.order_id,\n    o.customer_id,\n    o.customer_name,\n    o.customer_email,\n    o.customer_phone,\n\n    o.address1,\n    o.address2,\n    o.city,\n    o.state,\n    o.postal_code,\n    o.country,\n    o.country_code,\n\n    o.validation_status,\n\n    o.created_at,\n    o.updated_at,\n\n    l.confidence_score,\n    l.formatted_address,\n    l.latitude,\n    l.longitude,\n    l.place_id,\n\n    l.original_address,\n    l.corrected_address,\n\n    l.google_response\n\nFROM orders o\nLEFT JOIN address_validation_log l\n       ON o.order_id = l.order_id\n\nORDER BY o.created_at DESC;",
