    {
      "parameters": {
        "jsCode": "const orders = $input.all().map(item => item.json);\n\nconst summary = {\n  totalOrders: orders.length,\n  ready: orders.filter(o => o.validation_status === \"READY\").length,\n  readyWithCorrections: orders.filter(o => o.validation_status === \"READY_WITH_CORRECTIONS\").length,\n  reviewRequired: orders.filter(o => o.validation_status === \"REVIEW_REQUIRED\").length,\n  averageConfidence:\n    orders.length > 0\n      ? Number(\n          (\n            orders.reduce((sum, o) => sum + (o.confidence_score || 0), 0) /\n            orders.length\n          ).toFixed(1)\n        )\n      : 0,\n};\n\nreturn [\n  {\n    json: {\n      summary,\n      orders,\n    },\n  },\n];"
      },
